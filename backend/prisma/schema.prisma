generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model prisma_migrations {
  id                  String    @id @db.VarChar(36)
  checksum            String    @db.VarChar(64)
  finished_at         DateTime? @db.Timestamp(6)
  migration_name      String    @db.VarChar(255)
  logs                String?
  rolled_back         Boolean   @default(false)
  started_at          DateTime  @default(now()) @db.Timestamp(6)
  applied_steps_count Int       @default(0)

  @@map("_prisma_migrations")
}

model accessibility_types {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String?                 @db.VarChar(50)
  description           String?
  booking_accessibility booking_accessibility[]
  user_accessibility    user_accessibility[]
}

model ai_dynamic_pricing {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id      String?   @db.Uuid
  user_id         String?   @db.Uuid
  suggested_price Decimal?  @db.Decimal(12, 2)
  currency        String?   @db.VarChar(10)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  services        services? @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ai_dynamic_pricing_service")
  users           users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ai_dynamic_pricing_user")

  @@index([service_id], map: "idx_ai_dynamic_pricing_service")
  @@index([user_id], map: "idx_ai_dynamic_pricing_user")
}

model ai_logs {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String?              @db.Uuid
  prompt                String?
  response              String?
  created_at            DateTime?            @default(now()) @db.Timestamp(6)
  service_id            String?              @db.Uuid
  wallet_transaction_id String?              @db.Uuid
  services              services?            @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                 users?               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallet_transactions   wallet_transactions? @relation(fields: [wallet_transaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ai_memory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  key         String?
  value       String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  wallet_id   String?   @db.Uuid
  last_action String?   @db.VarChar(100)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallets     wallets?  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ai_recommendations {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  service_id String?   @db.Uuid
  score      Decimal?  @db.Decimal(5, 2)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  services   services? @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([service_id], map: "idx_ai_recommendations_service")
  @@index([user_id], map: "idx_ai_recommendations_user")
}

model ai_wallet_suggestions {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id        String?   @db.Uuid
  suggested_amount Decimal?  @db.Decimal(12, 2)
  reason           String?
  status           String?   @default("pending") @db.VarChar(50)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  wallets          wallets?  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([wallet_id], map: "idx_ai_wallet_suggestions_wallet")
}

model api_rate_limits {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  endpoint      String?   @db.VarChar(100)
  request_count Int?      @default(0)
  reset_at      DateTime? @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rate_limits_user")

  @@index([user_id, endpoint], map: "idx_rate_limits_user_endpoint")
}

model app_translations {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  translation_key String?   @db.VarChar(100)
  lang            String?   @db.VarChar(10)
  namespace       String?   @db.VarChar(50)
  value           String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  last_updated_by String?   @db.Uuid
  users           users?    @relation(fields: [last_updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([translation_key, lang, namespace], map: "unique_app_translation")
  @@index([translation_key, lang], map: "idx_app_translation")
}

model attachments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id String?   @db.Uuid
  file_url   String?
  file_type  String?   @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  messages   messages? @relation(fields: [message_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model audit_logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  action      String?
  entity_type String?   @db.VarChar(50)
  entity_id   String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_audit_logs_user")
}

model blocks {
  id                             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blocker_id                     String?   @db.Uuid
  blocked_id                     String?   @db.Uuid
  reason                         String?
  created_at                     DateTime? @default(now()) @db.Timestamp(6)
  users_blocks_blocked_idTousers users?    @relation("blocks_blocked_idTousers", fields: [blocked_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_blocks_blocker_idTousers users?    @relation("blocks_blocker_idTousers", fields: [blocker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model booking_accessibility {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id            String?              @db.Uuid
  accessibility_type_id String?              @db.Uuid
  notes                 String?
  accessibility_types   accessibility_types? @relation(fields: [accessibility_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bookings              bookings?            @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model bookings {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String?                 @db.Uuid
  service_id            String?                 @db.Uuid
  status                String?                 @default("pending") @db.VarChar(20)
  booking_time          DateTime?               @db.Timestamp(6)
  notes                 String?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  special_requirements  String?
  booking_priority      Int?                    @default(0)
  booking_accessibility booking_accessibility[]
  services              services?               @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                 users?                  @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_bookings_created_at")
  @@index([created_at], map: "idx_bookings_date")
  @@index([user_id], map: "idx_bookings_user")
}

model cache_store {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cache_key   String?   @unique @db.VarChar(255)
  cache_value Json?
  expires_at  DateTime? @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  @@index([cache_key], map: "idx_cache_key")
}

model calls {
  id                             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caller_id                      String?   @db.Uuid
  receiver_id                    String?   @db.Uuid
  type                           String?   @db.VarChar(20)
  status                         String?   @db.VarChar(20)
  started_at                     DateTime? @db.Timestamp(6)
  ended_at                       DateTime? @db.Timestamp(6)
  duration                       Int?
  users_calls_caller_idTousers   users?    @relation("calls_caller_idTousers", fields: [caller_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_calls_receiver_idTousers users?    @relation("calls_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model chat_members {
  chat_id                                              String     @db.Uuid
  user_id                                              String     @db.Uuid
  role                                                 String?    @default("member") @db.VarChar(20)
  joined_at                                            DateTime?  @default(now()) @db.Timestamp(6)
  unread_count                                         Int?       @default(0)
  is_muted                                             Boolean?   @default(false)
  last_read_message_id                                 String?    @db.Uuid
  chats                                                chats      @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                                                users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages_chat_members_last_read_message_idTomessages messages?  @relation("chat_members_last_read_message_idTomessages", fields: [last_read_message_id], references: [id], onUpdate: NoAction, map: "fk_last_read_message")
  messages_messages_chat_id_sender_idTochat_members    messages[] @relation("messages_chat_id_sender_idTochat_members")

  @@id([chat_id, user_id])
  @@index([user_id], map: "idx_chat_members_user")
}

model chats {
  id                                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_group                                 Boolean?       @default(false)
  name                                     String?        @db.VarChar(100)
  created_by                               String?        @db.Uuid
  created_at                               DateTime?      @default(now()) @db.Timestamp(6)
  last_message_id                          String?        @db.Uuid
  updated_at                               DateTime?      @default(now()) @db.Timestamp(6)
  chat_members                             chat_members[]
  users                                    users?         @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages_chats_last_message_idTomessages messages?      @relation("chats_last_message_idTomessages", fields: [last_message_id], references: [id], onUpdate: NoAction, map: "fk_last_message")
  messages_messages_chat_idTochats         messages[]     @relation("messages_chat_idTochats")

  @@index([last_message_id], map: "idx_chats_last_message")
}

model cities {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country_id String    @db.Uuid
  code       String    @db.VarChar(10)
  name       String    @db.VarChar(100)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  countries  countries @relation(fields: [country_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([code, country_id])
}

model countries {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String      @unique @db.VarChar(10)
  name       String      @db.VarChar(100)
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  cities     cities[]
  locations  locations[]
  users      users[]
}

model currencies {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String    @unique @db.VarChar(10)
  symbol     String?   @db.VarChar(10)
  name       String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users[]
}

model devices {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  device_name String?
  platform    String?
  push_token  String?
  last_seen   DateTime? @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model escrow_accounts {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_transaction_id String?              @db.Uuid
  status                String?              @default("pending") @db.VarChar(50)
  amount                Decimal?             @db.Decimal(12, 2)
  currency              String?              @db.VarChar(10)
  created_at            DateTime?            @default(now()) @db.Timestamp(6)
  wallet_transactions   wallet_transactions? @relation(fields: [wallet_transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([wallet_transaction_id], map: "idx_escrow_wallet_transaction")
}

model escrow_transactions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  service_id String?   @db.Uuid
  amount     Decimal   @db.Decimal(10, 2)
  status     String?   @default("pending") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  services   services? @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model exchange_rates {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  base_currency   String?   @db.VarChar(10)
  target_currency String?   @db.VarChar(10)
  rate            Decimal?  @db.Decimal(10, 4)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
}

model fraud_flags {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?              @db.Uuid
  wallet_id           String?              @db.Uuid
  transaction_id      String?              @db.Uuid
  reason              String?
  status              String?              @default("pending") @db.VarChar(50)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  wallet_transactions wallet_transactions? @relation(fields: [transaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fraud_flags_transaction")
  users               users?               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fraud_flags_user")
  wallets             wallets?             @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fraud_flags_wallet")

  @@index([user_id], map: "idx_fraud_flags_user")
  @@index([wallet_id], map: "idx_fraud_flags_wallet")
}

model friend_requests {
  id                                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                                String?   @db.Uuid
  receiver_id                              String?   @db.Uuid
  status                                   String?   @default("pending") @db.VarChar(20)
  created_at                               DateTime? @default(now()) @db.Timestamp(6)
  users_friend_requests_receiver_idTousers users?    @relation("friend_requests_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_friend_requests_sender_idTousers   users?    @relation("friend_requests_sender_idTousers", fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([receiver_id], map: "idx_friend_requests_receiver")
  @@index([sender_id], map: "idx_friend_requests_sender")
  @@index([status], map: "idx_friend_requests_status")
}

model friends {
  user_id                        String    @db.Uuid
  friend_id                      String    @db.Uuid
  created_at                     DateTime? @default(now()) @db.Timestamp(6)
  users_friends_friend_idTousers users     @relation("friends_friend_idTousers", fields: [friend_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_friends_user_idTousers   users     @relation("friends_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([user_id, friend_id])
}

model languages {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String    @unique @db.VarChar(10)
  name       String    @db.VarChar(100)
  is_rtl     Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users[]
}

model locations {
  id                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String?                   @db.Uuid
  address           String?
  geom              Unsupported("geography")?
  created_at        DateTime?                 @default(now()) @db.Timestamp(6)
  latitude          Float?
  longitude         Float?
  country_id        String?                   @db.Uuid
  city              String?                   @db.VarChar(100)
  timezone          String?                   @db.VarChar(50)
  formatted_address String?
  coordinates       Unsupported("geography")?
  utc_offset        Int?
  countries         countries?                @relation(fields: [country_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_location_country")
  users             users?                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  services          services[]

  @@index([latitude, longitude], map: "idx_locations_geo")
}

model media {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  url        String?
  type       String?   @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model message_reactions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id String?   @db.Uuid
  user_id    String?   @db.Uuid
  reaction   String?   @db.VarChar(10)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  messages   messages? @relation(fields: [message_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model message_status {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id String?   @db.Uuid
  user_id    String?   @db.Uuid
  status     String?   @db.VarChar(20)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  messages   messages? @relation(fields: [message_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([message_id, user_id], map: "unique_message_user")
  @@index([user_id], map: "idx_message_status_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model messages {
  id                                                       String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id                                                  String?             @db.Uuid
  sender_id                                                String?             @db.Uuid
  content                                                  String?
  type                                                     String?             @default("text") @db.VarChar(20)
  is_deleted                                               Boolean?            @default(false)
  created_at                                               DateTime?           @default(now()) @db.Timestamp(6)
  reply_to                                                 String?             @db.Uuid
  is_edited                                                Boolean?            @default(false)
  edited_at                                                DateTime?           @db.Timestamp(6)
  forwarded_from                                           String?             @db.Uuid
  attachments                                              attachments[]
  chat_members_chat_members_last_read_message_idTomessages chat_members[]      @relation("chat_members_last_read_message_idTomessages")
  chats_chats_last_message_idTomessages                    chats[]             @relation("chats_last_message_idTomessages")
  message_reactions                                        message_reactions[]
  message_status                                           message_status[]
  messages                                                 messages?           @relation("messagesTomessages", fields: [reply_to], references: [id], onUpdate: NoAction, map: "fk_reply")
  other_messages                                           messages[]          @relation("messagesTomessages")
  chat_members_messages_chat_id_sender_idTochat_members    chat_members?       @relation("messages_chat_id_sender_idTochat_members", fields: [chat_id, sender_id], references: [chat_id, user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sender_membership")
  chats_messages_chat_idTochats                            chats?              @relation("messages_chat_idTochats", fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                                                    users?              @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([chat_id], map: "idx_messages_chat")
  @@index([chat_id, created_at(sort: Desc)], map: "idx_messages_chat_created")
  @@index([created_at], map: "idx_messages_date")
  @@index([sender_id], map: "idx_messages_sender")
}

model notifications {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  title         String?   @db.VarChar(200)
  body          String?
  is_read       Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  notify_method String?   @default("default") @db.VarChar(20)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model payments {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?               @db.Uuid
  amount              Decimal?              @db.Decimal(10, 2)
  currency            String?               @db.VarChar(10)
  provider            String?               @db.VarChar(50)
  status              String?               @db.VarChar(20)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  fee                 Decimal?              @default(0) @db.Decimal(12, 2)
  payment_reference   String?               @db.VarChar(100)
  fraud_check         Boolean?              @default(false)
  users               users?                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallet_transactions wallet_transactions[]
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String?            @db.VarChar(100)
  role_permissions role_permissions[]
}

model reports {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id String?   @db.Uuid
  target_type String?   @db.VarChar(50)
  target_id   String?   @db.Uuid
  reason      String?
  status      String?   @default("open") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [reporter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  target_type String?   @db.VarChar(50)
  target_id   String?   @db.Uuid
  rating      Int?
  comment     String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_reviews_created_at")
  @@index([created_at], map: "idx_reviews_date")
  @@index([user_id], map: "idx_reviews_user")
}

model role_permissions {
