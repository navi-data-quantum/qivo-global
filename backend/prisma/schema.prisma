generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model accessibility_types {
  id                          Int                           @id @default(autoincrement())
  name                        String                        @db.VarChar(100)
  description                 String?
  icon                        String?                       @db.VarChar(100)
  category                    String?                       @db.VarChar(50)
  standard_code               String?                       @unique @db.VarChar(50)
  accessibility_types_i18n    accessibility_types_i18n[]
  service_accessibility       service_accessibility[]
  service_accessibility_score service_accessibility_score[]
  user_accessibility_profile  user_accessibility_profile[]
}

model accessibility_types_i18n {
  id                  Int                  @id @default(autoincrement())
  accessibility_id    Int?
  language_code       String?              @db.VarChar(5)
  name                String?              @db.VarChar(100)
  description         String?
  accessibility_types accessibility_types? @relation(fields: [accessibility_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([accessibility_id], map: "idx_accessibility_i18n_accessibility_id")
}

model ai_budget_profiles {
  id             BigInt    @id @default(autoincrement())
  user_id        Int?
  monthly_budget Decimal?  @db.Decimal(18, 2)
  travel_budget  Decimal?  @db.Decimal(18, 2)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  users          users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_ai_budget_profiles_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ai_feedback {
  id                   Int                   @id @default(autoincrement())
  interaction_id       Int?
  rating               Int?
  comment              String?
  created_at           DateTime?             @default(now()) @db.Timestamptz(6)
  ai_user_interactions ai_user_interactions? @relation(fields: [interaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ai_models {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @db.VarChar(100)
  type                 String?                @db.VarChar(50)
  version              String?                @db.VarChar(20)
  description          String?
  parameters           Json?
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  ai_user_interactions ai_user_interactions[]

  @@unique([name, version], map: "unique_model_version")
  @@index([type], map: "idx_ai_models_type")
}

model ai_user_interactions {
  id               Int           @id @default(autoincrement())
  user_id          Int?
  model_id         Int?
  input            Json
  output           Json
  interaction_type String?       @db.VarChar(50)
  created_at       DateTime?     @default(now()) @db.Timestamptz(6)
  ai_feedback      ai_feedback[]
  ai_models        ai_models?    @relation(fields: [model_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model app_translations {
  id               Int       @id @default(autoincrement())
  language_code    String    @db.VarChar(5)
  translation_key  String
  translation_text String
  languages        languages @relation(fields: [language_code], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@unique([language_code, translation_key])
}

model audit_logs {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  action     String    @db.VarChar(100)
  table_name String?   @db.VarChar(100)
  record_id  Int?
  old_data   Json?
  new_data   Json?
  ip_address String?   @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_audit_date")
  @@index([user_id], map: "idx_audit_user")
  @@index([user_id, created_at(sort: Desc)], map: "idx_audit_user_date")
}

model availability {
  id          Int       @id @default(autoincrement())
  provider_id Int?
  day_of_week Int       @db.SmallInt
  start_time  DateTime  @db.Time(6)
  end_time    DateTime  @db.Time(6)
  valid_from  DateTime? @db.Date
  valid_until DateTime? @db.Date
  is_active   Boolean?  @default(true)
  users       users?    @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([provider_id], map: "idx_availability_provider_id")
}

model booking_payments {
  id                  BigInt               @id @default(autoincrement())
  booking_id          Int?
  transaction_id      BigInt?
  amount              Decimal?             @db.Decimal(18, 2)
  status              String?              @db.VarChar(20)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  bookings            bookings?            @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wallet_transactions wallet_transactions? @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([booking_id], map: "idx_booking_payments_booking_id")
  @@index([transaction_id], map: "idx_booking_payments_transaction_id")
}

model booking_statuses {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                                                 Int                    @id @default(autoincrement())
  user_id                                            Int
  service_id                                         Int
  booking_date                                       DateTime               @db.Timestamp(6)
  status                                             String?                @default("confirmed") @db.VarChar(20)
  created_at                                         DateTime?              @default(now()) @db.Timestamp(6)
  updated_at                                         DateTime?              @default(now()) @db.Timestamp(6)
  duration_minutes                                   Int
  booked_price                                       Decimal                @db.Decimal(10, 2)
  booked_currency                                    String                 @db.VarChar(3)
  slot_id                                            Int?
  provider_id                                        Int?
  booking_payments                                   booking_payments[]
  services                                           services               @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  provider_slots_bookings_slot_idToprovider_slots    provider_slots?        @relation("bookings_slot_idToprovider_slots", fields: [slot_id], references: [id], onUpdate: NoAction)
  users_bookings_user_idTousers                      users                  @relation("bookings_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_bookings_provider_idTousers                  users?                 @relation("bookings_provider_idTousers", fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bookings_provider")
  platform_commissions                               platform_commissions[]
  provider_slots_provider_slots_booking_idTobookings provider_slots[]       @relation("provider_slots_booking_idTobookings")
  reviews                                            reviews[]

  @@unique([user_id, service_id, booking_date], map: "unique_booking")
  @@index([booking_date], map: "idx_bookings_date")
  @@index([service_id], map: "idx_bookings_service")
  @@index([service_id, booking_date(sort: Desc)], map: "idx_bookings_service_date")
  @@index([user_id], map: "idx_bookings_user")
  @@index([user_id, service_id, booking_date], map: "idx_bookings_user_service_date")
  @@index([user_id, service_id, booking_date(sort: Desc)], map: "idx_bookings_user_service_date_desc")
}

model cashback_rewards {
  id                  BigInt               @id @default(autoincrement())
  user_id             Int?
  transaction_id      BigInt?
  amount              Decimal?             @db.Decimal(18, 2)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  wallet_transactions wallet_transactions? @relation(fields: [transaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([transaction_id], map: "idx_cashback_rewards_transaction_id")
  @@index([user_id], map: "idx_cashback_rewards_user_id")
}

model categories {
  id            Int             @id @default(autoincrement())
  name          String          @unique(map: "categories_name_unique") @db.VarChar(100)
  icon          String?
  description   String?
  is_active     Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  services      services[]
  subcategories subcategories[]
}

model chat_attachments {
  id            Int            @id @default(autoincrement())
  message_id    Int?
  type          String         @db.VarChar(20)
  url           String
  size_kb       Int?
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  chat_messages chat_messages? @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([message_id], map: "idx_chat_attachments_message")
}

model chat_deleted {
  id            Int            @id @default(autoincrement())
  message_id    Int?
  deleted_by    Int?
  deleted_at    DateTime?      @default(now()) @db.Timestamp(6)
  reason        String?
  users         users?         @relation(fields: [deleted_by], references: [id], onUpdate: NoAction)
  chat_messages chat_messages? @relation(fields: [message_id], references: [id], onUpdate: NoAction)

  @@index([deleted_by], map: "idx_chat_deleted_deleted_by")
  @@index([message_id], map: "idx_chat_deleted_message")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chat_messages {
  id               Int                @id @default(autoincrement())
  session_id       Int
  sender_id        Int
  content          String
  is_free          Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  cost             Decimal?           @default(0) @db.Decimal(10, 2)
  status           String?            @default("sent") @db.VarChar(20)
  type             String?            @default("text") @db.VarChar(20)
  chat_attachments chat_attachments[]
  chat_deleted     chat_deleted[]
  users            users              @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chat_reactions   chat_reactions[]

  @@index([created_at(sort: Desc)], map: "idx_chat_messages_created")
  @@index([sender_id], map: "idx_chat_messages_sender")
  @@index([session_id], map: "idx_chat_messages_session")
  @@index([session_id, sender_id, created_at], map: "idx_chat_messages_session_sender")
  @@index([session_id, status, created_at(sort: Desc)], map: "idx_chat_messages_session_status")
  @@index([status], map: "idx_chat_messages_status")
}

model chat_participants {
  id            Int           @id @default(autoincrement())
  session_id    Int
  user_id       Int
  role          String?       @default("member") @db.VarChar(20)
  joined_at     DateTime?     @default(now()) @db.Timestamp(6)
  left_at       DateTime?     @db.Timestamp(6)
  last_read_at  DateTime?     @db.Timestamp(6)
  muted_until   DateTime?     @db.Timestamp(6)
  is_active     Boolean?      @default(true)
  chat_sessions chat_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chat_participants_session")
  users         users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chat_participants_user")

  @@unique([session_id, user_id], map: "unique_session_user")
  @@index([session_id, last_read_at], map: "idx_chat_participants_last_read")
  @@index([session_id], map: "idx_chat_participants_session")
  @@index([user_id], map: "idx_chat_participants_user")
}

model chat_reactions {
  id            Int            @id @default(autoincrement())
  message_id    Int?
  user_id       Int?
  emoji         String         @db.VarChar(10)
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  chat_messages chat_messages? @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users?         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([message_id, user_id, emoji])
  @@index([message_id], map: "idx_chat_reactions_message")
  @@index([message_id, emoji], map: "idx_chat_reactions_message_emoji")
}

model chat_sessions {
  id                 Int                  @id @default(autoincrement())
  message_count      Int?                 @default(0)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  last_message_at    DateTime?            @db.Timestamp(6)
  chat_participants  chat_participants[]
  chat_typing_status chat_typing_status[]
}

model chat_typing_status {
  session_id    Int
  user_id       Int
  is_typing     Boolean?      @default(false)
  last_update   DateTime?     @default(now()) @db.Timestamp(6)
  chat_sessions chat_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([session_id, user_id])
}

model cities {
  id            BigInt                    @id @default(autoincrement())
  name          String?                   @db.VarChar(100)
  country_code  String?                   @db.Char(2)
  population    BigInt?
  is_capital    Boolean?                  @default(false)
  lat           Float?
  lon           Float?
  geoname_id    BigInt?
  timezone_name String?
  region_id     Int?
  subregion_id  Int?
  geom          Unsupported("geography")?
  countries     countries?                @relation(fields: [country_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  timezones     timezones?                @relation(fields: [timezone_name], references: [name], onDelete: NoAction, onUpdate: NoAction, map: "fk_city_timezone")
  services      services[]
  users         users[]

  @@unique([name, country_code], map: "unique_city_country")
  @@index([country_code], map: "idx_cities_country")
  @@index([lat, lon], map: "idx_cities_geo")
  @@index([geom], map: "idx_cities_geom", type: Gist)
  @@index([geom], map: "idx_cities_geom_gist", type: Gist)
  @@index([name], map: "idx_cities_name")
  @@index([timezone_name], map: "idx_cities_timezone_name")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model countries {
  code                       String                       @id @db.VarChar(2)
  name                       String                       @db.VarChar(100)
  name_local                 String?                      @db.VarChar(100)
  region                     String?                      @db.VarChar(50)
  subregion                  String?                      @db.VarChar(50)
  currency_code              String                       @db.Char(3)
  flag_emoji                 String?                      @db.VarChar(5)
  capital_city               String?                      @db.VarChar(100)
  population                 BigInt?
  area_km2                   Decimal?                     @db.Decimal
  created_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  iso3_code                  String?                      @db.VarChar(3)
  cities                     cities[]
  currencies                 currencies                   @relation(fields: [currency_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  country_languages          country_languages[]
  country_official_languages country_official_languages[]
  services                   services[]
  users                      users[]

  @@index([region, subregion], map: "idx_countries_region_subregion")
}

model country_full_info_final {
  country_code  String      @id @db.Char(2)
  country_name  String      @db.VarChar(100)
  region        String?     @db.VarChar(50)
  subregion     String?     @db.VarChar(50)
  currency_code String      @db.Char(3)
  language_code String?     @db.Char(2)
  flag_emoji    String?     @db.VarChar(5)
  capital_city  String?     @db.VarChar(100)
  population    BigInt?
  area_km2      Decimal?    @db.Decimal
  region_id     Int?
  subregion_id  Int?
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  updated_at    DateTime?   @default(now()) @db.Timestamp(6)
  regions       regions?    @relation(fields: [region_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subregions    subregions? @relation(fields: [subregion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  currencies    currencies  @relation(fields: [currency_code], references: [code], map: "fk_country_full_info_currency")
  languages     languages?  @relation(fields: [language_code], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_language")

  @@index([currency_code], map: "idx_country_currency")
  @@index([subregion_id], map: "idx_country_full_info_subregion_id")
  @@index([language_code], map: "idx_country_language")
  @@index([region_id], map: "idx_country_region")
}

model country_info {
  country_code  String  @id @db.VarChar(2)
  currency_code String? @db.VarChar(3)
  language_code String? @db.VarChar(10)
  flag_emoji    String? @db.VarChar(5)
}

model country_languages {
  country_code     String    @db.VarChar(2)
  language_code    String    @db.VarChar(50)
  official         Boolean?  @default(false)
  primary_language Boolean?  @default(false)
  percentage       Decimal?  @db.Decimal(5, 2)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  dialect_of       String?   @db.VarChar(5)
  historical       Boolean?  @default(false)
  minority         Boolean?  @default(false)
  regional         Boolean?  @default(false)
  language_iso3    String?   @db.Char(3)
  languages        languages @relation(fields: [language_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  countries        countries @relation(fields: [country_code], references: [code], onDelete: Cascade, onUpdate: NoAction, map: "fk_country_languages_country")

  @@id([country_code, language_code])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model country_languages_global {
  country_code    String? @db.VarChar(2)
  country_name    String? @db.VarChar(100)
  languages       String?
  capital         String? @db.VarChar(100)
  continent       String? @db.VarChar(50)
  subregion       String? @db.VarChar(50)
  currency_code   String? @db.Char(3)
  currency_symbol String? @db.VarChar(10)

  @@ignore
}

model country_official_languages {
  country_code  String    @db.Char(2)
  language_code String    @db.Char(3)
  countries     countries @relation(fields: [country_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  languages     languages @relation(fields: [language_code], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@id([country_code, language_code])
}

model currencies {
  code                                                      String                    @id @db.VarChar(3)
  name                                                      String                    @db.VarChar(50)
  symbol                                                    String?                   @db.VarChar(5)
  symbol_new                                                String?                   @db.VarChar(50)
  countries                                                 countries[]
  country_full_info_final                                   country_full_info_final[]
  exchange_rates_exchange_rates_base_currencyTocurrencies   exchange_rates[]          @relation("exchange_rates_base_currencyTocurrencies")
  exchange_rates_exchange_rates_target_currencyTocurrencies exchange_rates[]          @relation("exchange_rates_target_currencyTocurrencies")
  services                                                  services[]
  users                                                     users[]
  wallets                                                   wallets[]
}

model device_sessions {
  id         BigInt    @id @default(autoincrement())
  user_id    Int?
  device_id  String?
  ip_address String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_device_sessions_user_id")
}

model entity_translations {
  id               Int       @id @default(autoincrement())
  entity_type      String    @db.VarChar(50)
  entity_id        Int
  field_name       String    @db.VarChar(50)
  language_code    String    @db.VarChar(5)
  translated_value String
  languages        languages @relation(fields: [language_code], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@unique([entity_type, entity_id, field_name, language_code])
}

model exchange_rates {
  id                                                    BigInt      @id @default(autoincrement())
  base_currency                                         String?     @db.VarChar(10)
  target_currency                                       String?     @db.VarChar(10)
  rate                                                  Decimal?    @db.Decimal(18, 6)
  updated_at                                            DateTime?   @default(now()) @db.Timestamp(6)
  currencies_exchange_rates_base_currencyTocurrencies   currencies? @relation("exchange_rates_base_currencyTocurrencies", fields: [base_currency], references: [code], onDelete: NoAction, onUpdate: NoAction)
  currencies_exchange_rates_target_currencyTocurrencies currencies? @relation("exchange_rates_target_currencyTocurrencies", fields: [target_currency], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@index([base_currency], map: "idx_exchange_rates_base")
  @@index([target_currency], map: "idx_exchange_rates_target")
}

model favorites {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  service_id Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  services   services? @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, service_id], map: "idx_favorites_user_service")
  @@index([user_id], map: "idx_favorites_user")
}

model fraud_checks {
  id                  BigInt               @id @default(autoincrement())
  transaction_id      BigInt?
  risk_score          Int?
  result              String?              @db.VarChar(20)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  wallet_transactions wallet_transactions? @relation(fields: [transaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([transaction_id], map: "idx_fraud_checks_transaction_id")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model geonames_temp {
  geonameid         Int?
  name              String?
  asciiname         String?
  alternatenames    String?
  latitude          String?
