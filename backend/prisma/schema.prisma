  feature_class     String?   @db.Char(1)
  feature_code      String?
  country_code      String?   @db.Char(2)
  cc2               String?
  admin1_code       String?
  admin2_code       String?
  admin3_code       String?
  admin4_code       String?
  population        BigInt?
