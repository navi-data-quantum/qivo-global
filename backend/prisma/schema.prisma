model wallet_limits {
  id            BigInt    @id @default(autoincrement())
  wallet_id     BigInt?
  daily_limit   Decimal?  @db.Decimal(18, 2)
  monthly_limit Decimal?  @db.Decimal(18, 2)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  wallets       wallets?  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([wallet_id], map: "idx_wallet_limits_wallet_id")
}

model wallet_topups {
  id         BigInt    @id @default(autoincrement())
  wallet_id  BigInt?
  amount     Decimal?  @db.Decimal(18, 2)
  method     String?   @db.VarChar(50)
  status     String?   @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  wallets    wallets?  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([wallet_id], map: "idx_wallet_topups_wallet_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model wallet_transactions {
  id               BigInt             @id @default(autoincrement())
  wallet_id        BigInt?
  type             String?            @db.VarChar(20)
  amount           Decimal?           @db.Decimal(18, 2)
  currency_code    String?            @db.VarChar(10)
  status           String?            @db.VarChar(20)
  reference_id     BigInt?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  booking_payments booking_payments[]
  cashback_rewards cashback_rewards[]
  fraud_checks     fraud_checks[]
  refunds          refunds[]
  wallets          wallets?           @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_transactions_created")
  @@index([wallet_id], map: "idx_transactions_wallet")
  @@index([wallet_id, created_at(sort: Desc)], map: "idx_wallet_transactions_wallet_created")
}

model wallet_withdrawals {
  id         BigInt    @id @default(autoincrement())
  wallet_id  BigInt?
  amount     Decimal?  @db.Decimal(18, 2)
  method     String?   @db.VarChar(50)
  status     String?   @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  wallets    wallets?  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([wallet_id], map: "idx_wallet_withdrawals_wallet_id")
}

model wallets {
  id                  BigInt                @id @default(autoincrement())
  user_id             Int?
  currency_code       String?               @db.VarChar(10)
  balance             Decimal?              @default(0) @db.Decimal(18, 2)
  status              String?               @default("active") @db.VarChar(20)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  wallet_limits       wallet_limits[]
  wallet_topups       wallet_topups[]
  wallet_transactions wallet_transactions[]
  wallet_withdrawals  wallet_withdrawals[]
  currencies          currencies?           @relation(fields: [currency_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  users               users?                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([currency_code], map: "idx_wallets_currency_code")
  @@index([user_id], map: "idx_wallets_user")
}
