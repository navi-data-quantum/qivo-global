model kyc_verifications {
  id              BigInt    @id @default(autoincrement())
  user_id         Int?
  document_type   String?   @db.VarChar(50)
  document_number String?
  status          String?   @db.VarChar(20)
  verified_at     DateTime? @db.Timestamp(6)
  users           users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_kyc_user_id")
}

model language_translations {
  language_code String    @db.VarChar(5)
  locale        String    @db.VarChar(5)
  name          String    @db.VarChar(100)
  languages     languages @relation(fields: [language_code], references: [code], onDelete: Cascade, onUpdate: NoAction)

  @@id([language_code, locale])
}

model languages {
  code                       String                       @id @db.VarChar(5)
  name                       String                       @db.VarChar(200)
  name_local                 String?                      @db.VarChar(200)
  iso3                       String?                      @db.VarChar(3)
  app_translations           app_translations[]
  country_full_info_final    country_full_info_final[]
  country_languages          country_languages[]
  country_official_languages country_official_languages[]
  entity_translations        entity_translations[]
  language_translations      language_translations[]
}

model languages_iso3 {
  iso3_code String  @id @db.VarChar(3)
